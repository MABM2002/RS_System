@using RS_system.Helpers;
@model Rs_system.Models.DiezmoSalida;
@{
    ViewData["Title"] = $"Recibo {ViewBag.NumeroRecibo}";
    Layout = null;

    // Desglose de fecha
    var fecha = Model.Fecha.ToLocalTime();
    var dia = fecha.ToString("dd");
    var mes = fecha.ToString("MM");
    var anio = fecha.ToString("yy");

    // Monto formateado
    var montoStr = Model.Monto.ToString("N2");

    // NOTA: No existe helper de conversión a letras en el proyecto.
    // Se muestra el monto numérico como referencia; el campo "letras"
    // queda disponible para impresión manual si se requiere.
    var montoEnLetras = string.Format("{0} DÓLARES ESTADOUNIDENSES", UtilidadesStatic.ConvertirNumeroALetras(Model.Monto)); // "[Monto en letras — agregar helper si se requiere]";

    var beneficiario = Model.Beneficiario?.Nombre ?? "No especificado";
    var concepto = Model.Concepto ?? "";
    var numeroRecibo = ViewBag.NumeroRecibo ?? "";
}

@inject Rs_system.Services.IConfiguracionService ConfigService
@{
    // NOTA: El nombre de la iglesia no está modelado.
    // Si se agrega una propiedad de configuración global, reemplazar aquí.
    var nombreIglesia = await ConfigService.GetValorOrDefaultAsync("NAME_CHURCH", "FarmMan");//"Iglesia — módulo de Diezmos";
}

<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Recibo @ViewBag.NumeroRecibo</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: #e0e0e0;
    font-family: Arial, sans-serif;
  }

  @@media print {
    body {
      background: white;
      margin: 0;
      padding: 0;
    }
    .no-print { display: none !important; }
    .page {
      margin: 0;
      padding: 0;
      box-shadow: none;
    }
    @@page {
      size: 8.5in 11in;
      margin: 0.5in;
    }
  }

  .no-print {
    text-align: center;
    padding: 12px;
    background: #1976d2;
    color: white;
    font-size: 14px;
    font-weight: bold;
    position: sticky;
    top: 0;
    z-index: 100;
    cursor: pointer;
  }
  .no-print button {
    background: white;
    color: #1976d2;
    border: none;
    padding: 6px 20px;
    border-radius: 4px;
    font-weight: bold;
    font-size: 14px;
    cursor: pointer;
    margin-left: 16px;
  }

  .page {
    width: 540pt;
    margin: 24px auto;
    background: white;
    box-shadow: 0 2px 12px rgba(0,0,0,0.2);
  }

  .receipt {
    position: relative;
    width: 540pt;
    height: 342pt;
    overflow: hidden;
  }

  .receipt img {
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  .receipt .img-placeholder {
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 100%;
    background: #f5f5f5;
    border: 2px dashed #bbb;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #999;
    font-size: 14px;
  }

  .field {
    position: absolute;
    background: transparent;
    border: none;
    outline: none;
    font-family: Arial, sans-serif;
    font-size: 12pt;
    color: #000;
    padding: 0;
    margin: 0;
    line-height: 1;
  }

  .field:focus {
    background: rgba(255,255,0,0.3);
  }

  .field-num {
    font-size: 10pt;
    font-weight: bold;
    color: red;
  }

  .field-letras {
    font-size: 9pt;
  }

  .field-x {
    font-family: 'Arial Black', Arial, sans-serif;
    font-weight: bold;
    font-size: 11pt;
  }

  @@media print {
    .field:focus {
      background: transparent;
    }
  }
</style>
</head>
<body>

<div class="no-print">
  📄 Recibo @ViewBag.NumeroRecibo — @(Model.TipoSalida?.Nombre ?? "Salida de Diezmos")
  <button onclick="window.print()">🖨️ Imprimir</button>
</div>

<div class="page">

  <!-- RECIBO 1 (Copia Original - parte superior) -->
  <div class="receipt" id="recibo1" style="border-style: solid; border-width:1px">
    <img src="~/Assets/recibotemplate.png" alt="Fondo del recibo" />

    <!-- N.º -->
    <input class="field field-num" style="left:444.35pt; top:44.6pt; width:80pt;"
      type="text" value="@numeroRecibo" readonly id="num1"/>

    <!-- Cantidad en número -->
    <input class="field" style="left:448.5pt; top:69.45pt; width:74pt;"
      type="text" value="@montoStr" readonly id="cantidad1"/>

    <!-- Nombre Iglesia -->
    <input class="field" style="left:121pt; top:103.35pt; width:272pt;"
      type="text" value="@nombreIglesia" readonly id="iglesia1"/>

    <!-- Dia -->
    <input class="field" style="left:412.3pt; top:114.65pt; width:23pt; text-align:center;"
      type="text" value="@dia" readonly maxlength="2" id="dia1"/>

    <!-- Mes -->
    <input class="field" style="left:450.5pt; top:114.55pt; width:23pt; text-align:center;"
      type="text" value="@mes" readonly maxlength="2" id="mes1"/>

    <!-- Año -->
    <input class="field" style="left:491.55pt; top:114.25pt; width:23pt; text-align:center;"
      type="text" value="@anio" readonly maxlength="2" id="year1"/>

    <!-- Cantidad en letras -->
    <input class="field field-letras" style="left:122.8pt; top:127.3pt; width:317pt;"
      type="text" value="@montoEnLetras" readonly id="letras1"/>

    <!-- Concepto -->
    <input class="field" style="left:121.75pt; top:151.9pt; width:284pt;"
      type="text" value="@concepto" readonly id="concepto1"/>

    <!-- X (checkmark) -->
    <input class="field field-x" style="left:175.1pt; top:200.25pt; width:15pt; text-align:center;"
      type="text" value="X" readonly maxlength="1" id="x1"/>

    <!-- Beneficiario -->
    <input class="field" style="left:34pt; top:298.2pt; width:231pt;"
      type="text" value="@beneficiario" readonly id="benef1"/>

  </div>

  <!-- RECIBO 2 (Copia - parte inferior) -->
  <div class="receipt" id="recibo2"  style="border-style: solid; border-width:1px">
    <img src="~/Assets/recibotemplate.png" alt="Fondo del recibo (copia)" />

    <!-- N.º -->
    <input class="field field-num" style="left:444.35pt; top:45.2pt; width:80pt;"
      type="text" value="@numeroRecibo" readonly id="num2"/>

    <!-- Cantidad en número -->
    <input class="field" style="left:445.75pt; top:70pt; width:74pt;"
      type="text" value="@montoStr" readonly id="cantidad2"/>

    <!-- Nombre Iglesia -->
    <input class="field" style="left:121.6pt; top:102.2pt; width:272pt;"
      type="text" value="@nombreIglesia" readonly id="iglesia2"/>

    <!-- Dia -->
    <input class="field" style="left:413pt; top:115.65pt; width:23pt; text-align:center;"
      type="text" value="@dia" readonly maxlength="2" id="dia2"/>

    <!-- Mes -->
    <input class="field" style="left:450.5pt; top:114.95pt; width:23pt; text-align:center;"
      type="text" value="@mes" readonly maxlength="2" id="mes2"/>

    <!-- Año -->
    <input class="field" style="left:492.8pt; top:115pt; width:23pt; text-align:center;"
      type="text" value="@anio" readonly maxlength="2" id="year2"/>

    <!-- Cantidad en letras -->
    <input class="field field-letras" style="left:120.9pt; top:127.15pt; width:319pt;"
      type="text" value="@montoEnLetras" readonly id="letras2"/>

    <!-- Concepto -->
    <input class="field" style="left:119.85pt; top:151.1pt; width:284pt;"
      type="text" value="@concepto" readonly id="concepto2"/>

    <!-- X (checkmark) -->
    <input class="field field-x" style="left:174.45pt; top:200.1pt; width:15pt; text-align:center;"
      type="text" value="X" readonly maxlength="1" id="x2"/>

    <!-- Beneficiario -->
    <input class="field" style="left:34.65pt; top:299.95pt; width:231pt;"
      type="text" value="@beneficiario" readonly id="benef2"/>

  </div>

</div>

</body>
</html>
