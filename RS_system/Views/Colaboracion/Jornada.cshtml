@model Rs_system.Models.ViewModels.ColaboracionHeadDetalleViewModel
@{
    ViewData["Title"] = $"Jornada del {Model.Fecha:dd/MM/yyyy}";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">Jornada del @Model.Fecha.ToString("dd/MM/yyyy")</h4>
        <p class="text-muted mb-0">Detalle de colaboraciones registradas en esta jornada</p>
    </div>
    <div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Volver a jornadas
        </a>
         @if (!Model.EsCerrado)
            {
                <a asp-action="Create" asp-route-jornada="@Model.Id" class="btn btn-primary-custom">
                <i class="bi bi-plus-lg me-1"></i> Nueva Colaboración
        </a>
        }
    </div>
</div>

<!-- Jornada Summary -->
<div class="row mb-4">
    <div class="col-md-2">
        <div class="card-custom text-center">
            <h6 class="text-muted mb-2">Total Recaudado</h6>
            <h3 class="text-success mb-0">$@Model.Total.ToString("N2")</h3>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card-custom text-center">
            <h6 class="text-muted mb-2">Cantidad</h6>
            <h3 class="text-primary mb-0">@Model.Colaboraciones.Count</h3>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card-custom text-center">
            <h6 class="text-muted mb-2">Estado</h6>
            @if (Model.EsCerrado)
            {
                <span class="badge bg-success fs-6">
                    <i class="bi bi-lock me-1"></i> Cerrado
                </span>
                <p class="mt-1 mb-0 small text-muted">
                    @Model.FechaCierre?.ToString("dd/MM/yyyy HH:mm")<br>
                    @(Model.CerradoPor ?? "Sistema")
                </p>
            }
            else
            {
                <span class="badge bg-warning text-dark fs-6">
                    <i class="bi bi-unlock me-1"></i> Abierto
                </span>
            }
        </div>
    </div>
    <div class="col-md-3">
        <div class="card-custom text-center">
            <h6 class="text-muted mb-2">Creado por</h6>
            <h5 class="mb-0">@(Model.CreadoPor ?? "Sistema")</h5>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card-custom text-center">
            <h6 class="text-muted mb-2">Creado en</h6>
            <h5 class="mb-0">@Model.CreadoEn.ToString("dd/MM/yyyy HH:mm")</h5>
        </div>
    </div>
</div>

@if (!Model.EsCerrado && Model.Total > 0)
{
    <div class="alert alert-info mb-4">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <i class="bi bi-info-circle me-2"></i>
                Esta jornada está abierta. Puede cerrarla para bloquear los registros y sincronizar con contabilidad.
            </div>
            <div>
                <form asp-action="CierreDiario" asp-route-id="@Model.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-success" 
                            onclick="return confirm('¿Está seguro de cerrar la jornada del @Model.Fecha.ToString("dd/MM/yyyy")?\\nTotal: $@Model.Total.ToString("N2")\\n\\nEsta acción bloqueará la jornada y creará un movimiento contable.')">
                        <i class="bi bi-lock me-1"></i> Cerrar Jornada
                    </button>
                </form>
            </div>
        </div>
    </div>
}

<!-- Colaboraciones Table -->
<div class="card-custom">
    <div class="card-header-custom">
        <h5 class="mb-0">Colaboraciones Registradas</h5>
    </div>
    <div class="table-responsive">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>Miembro</th>
                    <th>Monto</th>
                    <th>Tipos de Colaboración</th>
                    <th>Observaciones</th>
                    <th>Registrado por</th>
                    <th>Fecha Registro</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Colaboraciones.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            <i class="bi bi-cash-coin fs-1 d-block mb-2"></i>
                            No hay colaboraciones registradas en esta jornada
                        </td>
                    </tr>
                }
                @foreach (var colaboracion in Model.Colaboraciones)
                {
                    <tr>
                        <td>
                            <strong>@colaboracion.MiembroNombre</strong>
                        </td>
                        <td>
                            <strong class="text-success">$@colaboracion.MontoTotal.ToString("N2")</strong>
                        </td>
                        <td>
                            @foreach (var tipo in colaboracion.TiposColaboracion)
                            {
                                <span class="badge bg-primary me-1 mb-1">@tipo</span>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(colaboracion.Observaciones))
                            {
                                <small>@colaboracion.Observaciones</small>
                            }
                            else
                            {
                                <small class="text-muted">Sin observaciones</small>
                            }
                        </td>
                        <td>
                            <small>@(colaboracion.RegistradoPor ?? "Sistema")</small>
                        </td>
                        <td>
                            <small>@colaboracion.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</small>
                        </td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@colaboracion.Id" class="btn btn-sm btn-outline-primary" title="Ver detalles de colaboración">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        // Show success/error messages
        @if (TempData["Success"] != null)
        {
            <text>
            toastr.success('@TempData["Success"]');
            </text>
        }
        @if (TempData["Error"] != null)
        {
            <text>
            toastr.error('@TempData["Error"]');
            </text>
        }
    </script>
}